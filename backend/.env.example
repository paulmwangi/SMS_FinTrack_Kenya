PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sms_fintrack?schema=public"

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@smsfintrack.co.ke

# Africa's Talking
AT_API_KEY=your-africas-talking-api-key
AT_USERNAME=your-africas-talking-username

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Cloud Storage (Cloudflare R2 or S3)
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=sms-fintrack-pdfs

# App Configuration
APP_NAME=SMS-FinTrack Kenya
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
